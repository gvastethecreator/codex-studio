{
  "name": "codex-image-studio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "dev:ui": "vite --config vite.config.ts",
    "dev:server": "bun apps/local-server/src/index.ts",
    "studio:init": "bun run scripts/studio-init.ts",
    "build": "bun run build:ui && bun run build:server",
    "build:ui": "vite build --config vite.config.ts",
    "build:server": "tsc --noEmit -p apps/local-server/tsconfig.json",
    "check": "tsc --noEmit",
    "preview": "vite preview",
    "lint": "bun run check"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/three": "^0.183.1",
    "clsx": "^2.1.1",
    "file-saver": "^2.0.5",
    "hono": "^4.10.7",
    "js-yaml": "^4.1.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.417.0",
    "motion": "12.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "three": "^0.183.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.4",
    "@types/file-saver": "^2.0.7",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "typescript": "~5.8.2",
    "vite": "^7.3.0"
  }
}
