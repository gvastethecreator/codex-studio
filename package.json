{
  "name": "codex-studio",
  "version": "0.0.0",
  "private": true,
  "description": "Local-first studio to generate and manage images with Codex/ChatGPT via codex app-server.",
  "keywords": [
    "bun",
    "chatgpt",
    "codex",
    "hono",
    "image-generation",
    "local-first",
    "react"
  ],
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "dev:ui": "vp dev",
    "dev:server": "bun apps/local-server/src/index.ts",
    "dev:electron": "bun run scripts/dev-electron.ts",
    "studio:init": "bun run scripts/studio-init.ts",
    "assets:migrate:webp": "bun run scripts/migrate-image-assets-to-webp.ts",
    "assets:character-lab:icons": "bun run scripts/build-character-lab-icon-assets.ts",
    "assets:character-lab:option-icons": "bun run scripts/build-character-lab-option-icon-assets.ts",
    "styles:split": "bun run scripts/split-style-preset-manifests.ts",
    "styles:scaffold": "bun run scripts/scaffold-style-preset.ts",
    "styles:validate": "bun run scripts/validate-style-preset-manifests.ts",
    "styles:taxonomy": "bun run scripts/backfill-style-preset-taxonomy.ts",
    "styles:catalog": "bun run scripts/query-style-preset-catalog.ts",
    "styles:runtime": "bun run scripts/generate-style-runtime-data.ts",
    "styles:runtime:check": "bun run scripts/generate-style-runtime-data.ts --check",
    "styles:templates:verify": "bun run scripts/validate-style-preset-templates.ts",
    "styles:source:verify": "bun run scripts/style-authoring-source-audit.ts",
    "styles:quality:audit": "bun run scripts/audit-style-preset-quality.ts",
    "styles:thumbs": "bun run scripts/build-style-pack-card-thumbnails.ts",
    "styles:pack-thumbs": "bun run scripts/build-style-pack-card-thumbnails.ts",
    "styles:verify": "bun run styles:validate -- --coverage --strict-taxonomy && bun run styles:runtime:check && bun run styles:templates:verify && bun run styles:source:verify && bun run styles:render:verify",
    "styles:browser": "tsx ./scripts/verify-styles-browser-gate.ts",
    "styles:browser:verify": "tsx ./scripts/verify-styles-browser-gate.ts --verify",
    "recipes:catalog": "bun run scripts/query-recipe-modules.ts",
    "recipes:examples:verify": "bun run scripts/validate-recipe-module-examples.ts",
    "recipes:source:verify": "bun run scripts/recipe-module-source-audit.ts",
    "recipes:verify": "bun run scripts/query-recipe-modules.ts --verify && bun run recipes:examples:verify && bun run recipes:source:verify && bun run recipes:evaluate -- --verify",
    "recipes:evaluate": "bun run scripts/evaluate-recipe-prompts.ts",
    "recipes:evaluate:live": "bun run scripts/evaluate-recipe-prompts-live.ts",
    "providers:audit": "bun run scripts/audit-provider-inputs.ts",
    "providers:source:verify": "bun run scripts/provider-boundary-source-audit.ts",
    "providers:verify": "bun run providers:audit -- --verify && bun run providers:source:verify",
    "providers:preflight": "bun run scripts/query-provider-runtime.ts",
    "catalog:source:verify": "bun run scripts/catalog-first-source-audit.ts",
    "library:layout:verify": "bun run scripts/studio-library-layout-source-audit.ts",
    "storage:audit": "bun run scripts/studio-storage-maintenance.ts audit",
    "storage:compact": "bun run scripts/studio-storage-maintenance.ts compact",
    "storage:thumbnails:backfill": "bun run scripts/studio-storage-maintenance.ts thumbnails:backfill",
    "ui:chunks": "bun run scripts/report-ui-chunks.ts",
    "ui:chunks:verify": "bun run scripts/report-ui-chunks.ts --verify",
    "ui:source:verify": "bun run scripts/ui-demand-surface-audit.ts",
    "ui:responsive": "tsx ./scripts/verify-responsive-mobile.ts",
    "ui:responsive:verify": "tsx ./scripts/verify-responsive-mobile.ts --verify",
    "styles:render": "bun run scripts/report-style-render-budget.ts",
    "styles:render:verify": "bun run scripts/report-style-render-budget.ts --verify",
    "fmt": "bun run scripts/tooling-task.ts fmt",
    "fmt:check": "bun run scripts/tooling-task.ts fmt:check",
    "lint": "bun run scripts/tooling-task.ts lint",
    "lint:fix": "bun run scripts/tooling-task.ts lint:fix",
    "check": "bun run scripts/tooling-task.ts check",
    "check:fix": "bun run scripts/tooling-task.ts check:fix",
    "test": "bun run scripts/tooling-task.ts test",
    "test:unit": "bun run scripts/tooling-task.ts test:unit",
    "test:coverage": "bun run scripts/tooling-task.ts test:coverage",
    "build": "bun run scripts/tooling-task.ts build",
    "build:ui": "bun run scripts/tooling-task.ts build:ui",
    "build:server": "bun run scripts/tooling-task.ts build:server",
    "validate:fast": "bun run scripts/tooling-task.ts validate:fast",
    "validate:full": "bun run scripts/tooling-task.ts validate:full",
    "preview": "vp preview",
    "preview:electron": "bun run scripts/preview-electron.ts",
    "tooling:logs": "bun run scripts/open-tooling-logs.ts",
    "tooling:logs:prune": "bun run scripts/tooling-task.ts tooling:logs:prune",
    "doctor": "npx react-doctor@latest"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.8",
    "@fal-ai/client": "^1.10.1",
    "@gsap/react": "^2.1.2",
    "@tabler/icons-react": "^3.44.0",
    "clsx": "^2.1.1",
    "effect": "^3.21.4",
    "file-saver": "^2.0.5",
    "gsap": "^3.15.0",
    "hono": "^4.12.27",
    "js-yaml": "^5.2.0",
    "jszip": "^3.10.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.2",
    "tailwind-merge": "^3.6.0",
    "three": "^0.185.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/bun": "^1.3.14",
    "@types/file-saver": "^2.0.7",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^42.5.1",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "playwright": "^1.61.1",
    "react-scan": "^0.5.7",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.22.4",
    "typescript": "~6.0.3",
    "vite": "8.1.0",
    "vite-plus": "^0.2.1"
  },
  "overrides": {
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "vite": "8.1.0"
  },
  "packageManager": "bun@1.3.14"
}
